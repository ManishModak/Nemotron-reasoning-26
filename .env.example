# Copy to .env and fill in (see scripts/openrouter_taskcot.py). Do not commit .env.

# Default provider is NVIDIA (scripts/openrouter_taskcot.py --provider nvidia).
# Key from https://build.nvidia.com -> model page -> Get API Key (nvapi-...)
NVIDIA_API_KEY=
# NVAPI_KEY=

OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=nemotron-openrouter-taskcot
